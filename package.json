{
  "name": "conexao-municipal",
  "version": "0.1.0",
  "private": true,
  "description": "Conexão Municipal — monorepo (web + api + shared). Ver SDD-ConexaoMunicipal.md",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run start:dev -w api",
    "build": "npm run build -w api && npm run build -w web",
    "start": "npm run start:prod -w api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22"
  }
}
