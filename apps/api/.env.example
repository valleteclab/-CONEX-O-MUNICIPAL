PORT=3001
NODE_ENV=development

# Origens permitidas para o browser (Next em outro domínio). Lista separada por vírgula.
# Local: http://localhost:3000
# Railway: https://seu-front.up.railway.app
# CORS_ORIGINS=http://localhost:3000,https://conexao-municipal-production-xxxx.up.railway.app

# Local: variáveis separadas. Railway / PaaS: use DATABASE_URL (substitui as de baixo).
# DATABASE_URL=postgres://user:pass@host:5432/railway
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=conexao
DATABASE_PASSWORD=conexao_dev
DATABASE_NAME=conexao_municipal
# DATABASE_SSL=false

# Schema: use migrations (npm run migration:run). synchronize só em emergência local.
TYPEORM_SYNC=false
# Executar migrations ao arrancar a API (Railway / Docker com entrypoint).
TYPEORM_MIGRATIONS_RUN=false
# TYPEORM_LOGGING=true

JWT_SECRET=troque-em-producao-min-32-chars-ok
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

DEFAULT_TENANT_SLUG=luis-eduardo-magalhaes

# Redefinição de senha (token em dev vai para stderr da API)
PASSWORD_RESET_EXPIRES_MINUTES=60
