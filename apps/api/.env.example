PORT=3001
NODE_ENV=development

# Origens permitidas para o browser (Next em outro domínio). Lista separada por vírgula.
# Local: http://localhost:3000
# Railway: https://seu-front.up.railway.app
# CORS_ORIGINS=http://localhost:3000,https://conexao-municipal-production-xxxx.up.railway.app

# Local: variáveis separadas. Railway / PaaS: use DATABASE_URL (substitui as de baixo).
# DATABASE_URL=postgres://user:pass@host:5432/railway
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=conexao
DATABASE_PASSWORD=conexao_dev
DATABASE_NAME=conexao_municipal
# DATABASE_SSL=false

# Schema: use migrations (npm run migration:run). synchronize só em emergência local.
TYPEORM_SYNC=false
# Executar migrations ao arrancar a API (Railway / Docker com entrypoint).
TYPEORM_MIGRATIONS_RUN=false
# TYPEORM_LOGGING=true

JWT_SECRET=troque-em-producao-min-32-chars-ok
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

DEFAULT_TENANT_SLUG=luis-eduardo-magalhaes

# YouTube Data API v3 (playlists completas, duração dos vídeos no admin Academia — opcional; sem chave, RSS limitado e sem duração automática)
# YOUTUBE_API_KEY=

# Redefinição de senha (token em dev vai para stderr da API)
PASSWORD_RESET_EXPIRES_MINUTES=60

# PlugNotas — emissão de NFS-e / NF-e (sandbox público por padrão)
PLUGNOTAS_API_KEY=2da392a6-79d2-4304-a8b7-959572c7e44d
PLUGNOTAS_BASE_URL=https://api.sandbox.plugnotas.com.br
# PLUGNOTAS_SANDBOX=true          # false para produção
# PLUGNOTAS_WEBHOOK_SECRET=       # segredo para validar callbacks
# URL pública da API (ex. https://api-production-xxx.up.railway.app) — usada no registro da empresa PlugNotas para webhook
# API_PUBLIC_URL=

# Consulta CNPJ (Invertexto) — cadastro ERP /erp/cnpj/:cnpj e página /erp/cadastrar-negocio
# Obtenha o token no painel Invertexto; sem isto a consulta retorna 503
# CNPJ_API_TOKEN=
# CNPJ_API_BASE_URL=https://api.invertexto.com/v1/cnpj

# IA (OpenRouter) — classificação fiscal (NCM/CFOP/origem) em lote
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
